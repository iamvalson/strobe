# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit real credentials.

# Base URL of the Go backend.
# Used by next.config.ts to proxy /api/* requests, avoiding CORS in development.
# In production point this at your deployed backend (e.g. https://api.yourapp.com).
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket URL for real-time probe results.
# Must use ws:// (or wss:// in production with TLS).
# If omitted, the UI falls back to ws://<same-hostname>:8080/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws
